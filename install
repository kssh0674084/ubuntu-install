#!/bin/bash

# 自动获取目录，换服务器随便用
BASE_DIR=$(cd "$(dirname "$0")" && pwd)
cd "$BASE_DIR"

# 修复Python路径 & 翻译模块
export PYTHONPATH="$BASE_DIR"

# 无限循环主菜单
while true
do
    clear
    echo "======================================================================"
    echo "      深度学习环境一键安装脚本"
    echo "======================================================================"
    echo "--- 各类工具，随时可用 ---"
    echo ""
    echo "配置工具:"
    echo "  [1]:一键配置:系统源(更换系统源,支持全版本Ubuntu系统)"
    echo "  [2]:一键安装并开启SSH服务"
    echo "  [3]:一键安装NVIDIA显卡驱动"
    echo "  [4]:一键安装CUDA (默认13.1)"
    echo "  [5]:一键安装NCCL (GPU通信库)"
    echo "  [6]:一键安装Conda3"
    echo "  [7]:一键安装NVIDIA-P2P驱动"
    echo "  [8]:一键卸载NVIDIA驱动（卸载后不可恢复）"
    echo "  [9]:一键安装Docker & Docker Compose"
    echo ""
    echo "[0]:退出"
    echo ""

    read -p "请输入[]内的数字选择功能:" num

    # 0 退出
    if [ "$num" = "0" ]; then
        exit 0
    fi

    # 执行脚本（全部统一等待，不会没反应）
    if [ "$num" = "1" ]; then
        cd "$BASE_DIR" && python3 -m tools.tool_config_system_source
    elif [ "$num" = "2" ]; then
        cd "$BASE_DIR" && python3 -m tools.tool_install_ssh
    elif [ "$num" = "3" ]; then
        cd "$BASE_DIR" && python3 -m tools.tool_install_nvidia_driver
    elif [ "$num" = "4" ]; then
        cd "$BASE_DIR" && python3 -m tools.tool_install_cuda
    elif [ "$num" = "5" ]; then
        cd "$BASE_DIR" && python3 -m tools.tool_install_nccl
    elif [ "$num" = "6" ]; then
        cd "$BASE_DIR" && python3 -m tools.tool_install_conda
    elif [ "$num" = "7" ]; then
        chmod +x "$BASE_DIR/tools/nvidia_install.sh"
        bash "$BASE_DIR/tools/nvidia_install.sh"
    elif [ "$num" = "8" ]; then
        echo -e "\n============================================================="
        echo -e "\033[31m⚠️  警告：卸载NVIDIA驱动后不可恢复！\033[0m"
        echo -e "=============================================================\n"
        read -p "确定要卸载NVIDIA驱动吗？(y/n): " confirm
        if [ "$confirm" = "y" ] || [ "$confirm" = "Y" ]; then
            echo -e "\n🚨 开始卸载驱动..."
            sudo /usr/bin/nvidia-uninstall
            echo -e "\n✅ 驱动卸载完成！"
        else
            echo -e "\n✅ 已取消卸载！"
        fi
    elif [ "$num" = "9" ]; then
        echo -e "\n🐳 开始安装 Docker & Docker Compose..."
        chmod +x "$BASE_DIR/tools/docker&compose.sh"
        bash "$BASE_DIR/tools/docker&compose.sh"
        echo -e "\n✅ Docker 安装完成！"
    fi

    echo -e "\n按回车键返回主菜单..."
    read dummy

done
